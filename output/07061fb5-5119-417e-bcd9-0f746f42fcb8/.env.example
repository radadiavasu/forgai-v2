# Server
NODE_ENV=development
PORT=3001

# Database
# Full PostgreSQL connection URL
DATABASE_URL=postgresql://taskuser:taskpassword@localhost:5432/taskmanager

# Individual database credentials (used by docker-compose)
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpassword
POSTGRES_DB=taskmanager

# JWT
# Secret key for signing JWT tokens — change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS
# URL of the frontend application
FRONTEND_URL=http://localhost:3000