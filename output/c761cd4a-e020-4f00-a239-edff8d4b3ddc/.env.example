# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgres://taskuser:taskpassword@localhost:5432/taskmanager

# PostgreSQL individual settings (used by docker-compose)
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpassword
POSTGRES_DB=taskmanager

# JWT Secret (for future auth use)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d